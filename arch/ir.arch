%name IR
%version 1

#include <city/module/Block.h>
#include <city/module/Value.h>

encoding dynamic {
    binary {
        city::Value lhs
        city::Value rhs
    }

    unary {
        city::Value value
    }
}

instruction {
    add binary
    sub binary
    div binary
    mul binary
    cmp binary

    write {
        std::string name
        city::Value value
    }
    read {
        std::string name
    }

    branch unary
    call unary
    ret unary
}

register {
}